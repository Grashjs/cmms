<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
    <changeSet id="2026_06_11_shift_configuration" author="Ibrahima G. Coulibaly">
        <comment>Create shift_configuration table and related tables for user shift configuration</comment>

        <createTable tableName="shift_configuration">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="BIGINT"/>
            <column name="updated_by" type="BIGINT"/>
        </createTable>

        <createTable tableName="shift_configuration_days">
            <column name="shift_configuration_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_shift_config_days_config"
                             references="shift_configuration(id)"
                             deleteCascade="true"/>
            </column>
            <column name="day_of_week" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="availability_minutes" type="INT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="shift_configuration_exceptions">
            <column name="shift_configuration_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_shift_config_exceptions_config"
                             references="shift_configuration(id)"
                             deleteCascade="true"/>
            </column>
            <column name="exception_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="availability_minutes" type="INT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addColumn tableName="own_user">
            <column name="shift_configuration_id" type="BIGINT"/>
        </addColumn>

        <addForeignKeyConstraint
                baseTableName="own_user"
                baseColumnNames="shift_configuration_id"
                referencedTableName="shift_configuration"
                referencedColumnNames="id"
                constraintName="fk_own_user_shift_config"
                onDelete="SET NULL"/>

        <createSequence sequenceName="shift_configuration_seq" startValue="1" incrementBy="50"/>
    </changeSet>
    <changeSet id="1781193062134-1" author="Ibrahima G. Coulibaly">
        <addColumn tableName="shift_configuration">
            <column name="enabled" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>
    <changeSet id="1781193577010-1" author="">
        <addColumn tableName="shift_configuration_days">
            <column name="enabled" type="boolean">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>
    <changeSet id="1781195672060-1" author="Ibrahima G. Coulibaly">
        <addColumn tableName="shift_configuration_exceptions">
            <column name="enabled" type="boolean">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>
    <changeSet id="1781204481351-1" author="Ibrahima G. Coulibaly">
        <sql>
            INSERT INTO subscription_plan_features (subscription_plan_id, features)
            SELECT id, 16
            FROM subscription_plan
            WHERE code = 'BUSINESS';
</sql>
    </changeSet>
</databaseChangeLog>
